# Required – Azure OpenAI
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Email recipient
EMAIL_TO=you@example.com

# Azure Communication Services (ACS) – Email
# Connection string from your ACS resource (Keys blade in Azure Portal)
ACS_CONNECTION_STRING=endpoint=https://<resource>.communication.azure.com/;accesskey=<key>
# Verified sender address from your ACS Email Communication Service domain
# (e.g. the auto-provisioned DoNotReply address, or a custom verified domain)
ACS_SENDER_ADDRESS=DoNotReply@<subdomain>.azurecomm.net

# Optional – Azure OpenAI API version, defaults to 2024-12-01-preview
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Optional – Report language (ISO 639-1 code, e.g. "en", "pl", "de"). Default: en
REPORT_LANGUAGE=en
